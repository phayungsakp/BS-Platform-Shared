REACT_APP_API_URL=http://10.10.60.66/api_gateway/timesheet/v1/api
REACT_APP_API_LICENSE_KEY=""
REACT_APP_ENCRYPYION="TIMESHEET-2025-APP"
# Database Configuration
REACT_APP_DEFAULT_SCHEMA=tmt

# Secret key สำหรับการเข้ารหัสข้อมูลใน localStorage
# แนะนำให้ใช้ key ที่แข็งแรงอย่างน้อย 32 ตัวอักษร
REACT_APP_STORAGE_SECRET=your-super-secret-encryption-key-here-32-chars

# MUI X License Configuration
# Get your license key from: https://mui.com/store/
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
REACT_APP_MUI_X_LICENSE_KEY=

# Environment mode
REACT_APP_ENV=development

# Debug mode
REACT_APP_DEBUG=true

# Session timeout (in milliseconds)
REACT_APP_SESSION_TIMEOUT=3600000

# Application name
REACT_APP_NAME="Timesheet"

# Version
REACT_APP_VERSION=1.0.0

#base url
REACT_APP_BASE_URL=/timesheet


# Date/Time Format Configuration
# Format for date only fields (used in DatePicker and grid display)
# Examples: DD/MM/YYYY, MM/DD/YYYY, YYYY-MM-DD
REACT_APP_DATE_FORMAT=DD/MM/YYYY

# Format for datetime fields (used in DateTimePicker and grid display)
# Examples: DD/MM/YYYY HH:mm, MM/DD/YYYY hh:mm A, YYYY-MM-DD HH:mm:ss
REACT_APP_DATETIME_FORMAT=DD/MM/YYYY HH:mm

# Use 24-hour format (true) or 12-hour AM/PM format (false)
REACT_APP_USE_24_HOUR=true

# Enable verbose debug logs in BSDataGrid (default: false)
REACT_APP_BSDATAGRID_VERBOSE_LOG=false

REACT_APP_NOTIFY_URL=http://10.10.60.66/bs-notification