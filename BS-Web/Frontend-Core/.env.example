# BS Platform Environment Configuration

# Default database schema
# ถ้าไม่ระบุ bsPreObj จะใช้ schema นี้เป็น default
# ถ้าไม่กำหนดตัวแปรนี้ จะใช้ "dbo" เป็น default
REACT_APP_DEFAULT_SCHEMA=tmt

# Alternative environment variable names (any of these will work):
# DEFAULT_SCHEMA=tmt
# DB_DEFAULT_SCHEMA=tmt

# Date/Time Format Configuration
# Format for date only fields (used in DatePicker and grid display)
# Examples: DD/MM/YYYY, MM/DD/YYYY, YYYY-MM-DD
REACT_APP_DATE_FORMAT=DD/MM/YYYY

# Format for datetime fields (used in DateTimePicker and grid display)
# Examples: DD/MM/YYYY HH:mm, MM/DD/YYYY hh:mm A, YYYY-MM-DD HH:mm:ss
REACT_APP_DATETIME_FORMAT=DD/MM/YYYY HH:mm

# Use 24-hour format (true) or 12-hour AM/PM format (false)
REACT_APP_USE_24_HOUR=true

# Enable verbose debug logs in BSDataGrid (default: false)
REACT_APP_BSDATAGRID_VERBOSE_LOG=false

# Other environment variables...
# REACT_APP_API_URL=http://localhost:5000/api
# REACT_APP_LICENSE_KEY=your-license-key